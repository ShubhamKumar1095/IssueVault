APP_NAME=IssueVault
APP_ENV=local
APP_SECRET_KEY=change-this-secret
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
ALLOWED_EXTENSIONS=png,jpg,jpeg,pdf,txt,log,csv,json,zip

ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
